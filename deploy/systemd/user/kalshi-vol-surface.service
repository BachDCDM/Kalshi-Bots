# Install: cp to ~/.config/systemd/user/ then daemon-reload. Adjust %h/kalshi-trading if needed.

[Unit]
Description=Kalshi vol-surface strategy (BTC hourly + weather)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/kalshi-trading
EnvironmentFile=-%h/kalshi-trading/.env
# Weather-only (disable BTC hourly in this process): uncomment next line, then daemon-reload + restart.
# Environment=VOL_SURFACE_SKIP_BTC_HOURLY=1
ExecStart=%h/kalshi-trading/.venv/bin/python -m vol_surface_strategy.main
Restart=on-failure
RestartSec=12

[Install]
WantedBy=default.target
