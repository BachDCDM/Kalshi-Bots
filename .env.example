# Kalshi API Credentials
# Get these from your Kalshi account settings
KALSHI_API_KEY=your_api_key_here
KALSHI_API_SECRET=your_api_secret_here

# Kalshi API URLs
# Production: https://trading-api.kalshi.com/trade-api/v2
# Demo: https://demo-api.kalshi.co/trade-api/v2
KALSHI_API_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://trading-api.kalshi.com/trade-api/ws/v2

# Target market to trade
# Example: KXNBA-25JAN14-GSW-YES for a specific NBA game winner market
TARGET_MARKET_TICKER=your_target_market_ticker

# Risk Management
MAX_POSITION_SIZE=10
MAX_CONTRACTS_PER_TRADE=5

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Optional: Override default strategy parameters
# Uncomment and modify as needed
# UPDATE_CADENCE=1.0
# BASELINE_WINDOW=120
# VOLATILITY_WINDOW=60
# SHOCK_WINDOW=10
# MIN_SHOCK=0.06
# SHOCK_MULTIPLIER=3.0
# MIN_DEVIATION=0.04
# DEVIATION_MULTIPLIER=2.0
# ENTRY_FILL_TIMEOUT=5.0
# EXIT_BAND_FLOOR=0.015
# MAX_HOLD_TIME=180
# REPEAT_SHOCK_WINDOW=30
# COOLDOWN_DURATION=60
# MIN_TTS=180
# DATA_STALE_THRESHOLD=5.0
