# Copy this file to ".env" in the same folder and fill in your values.
# Never commit .env (it is listed in .gitignore).

KALSHI_API_KEY_ID=

# Recommended: create kalshi.pem next to btc15m_bot.py with ONLY your PEM (BEGIN/END lines).
KALSHI_PRIVATE_KEY_PATH=kalshi.pem

# Alternative: absolute path to any .pem file
# KALSHI_PRIVATE_KEY_PATH=/Users/you/.secrets/kalshi.pem

# Alternative: one line in .env with \n between PEM lines (multiline in .env is unreliable)
# KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# Optional — uncomment if needed
# KALSHI_HOST=https://api.elections.kalshi.com/trade-api/v2
# KALSHI_HOST=https://demo-api.kalshi.co/trade-api/v2
# KALSHI_SERIES_TICKER=KXBTC15M
# KALSHI_CONTRACTS=10
# KALSHI_ENTRY_CENTS=25
# KALSHI_EXIT_CENTS=50
# KALSHI_ENTRY_WINDOW_MINUTES=5
# KALSHI_POLL_SECONDS=1.0
