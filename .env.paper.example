# Copy to .env.paper and fill in KALSHI_API_KEY_ID + kalshi-paper.pem
# Keys from https://demo.kalshi.co only.

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=kalshi-paper.pem
KALSHI_HOST=https://demo-api.kalshi.co/trade-api/v2

KALSHI_ENTRY_CENTS=10
KALSHI_EXIT_CENTS=20
KALSHI_ENTRY_WINDOW_MINUTES=7
KALSHI_CONTRACTS=10
KALSHI_SERIES_TICKER=KXBTC15M
KALSHI_POLL_SECONDS=1.0
